# Network: devnet (safe first test, free SOL) or mainnet (Service Level 12 = real-time World Cup)
TXLINE_NETWORK=devnet

# Optional custom RPC. Network-specific vars win over the generic one; empty
# falls back to the public RPC of the selected network.
SOLANA_RPC_URL=
SOLANA_RPC_URL_DEVNET=
SOLANA_RPC_URL_MAINNET=

# Path to the server wallet keypair (JSON array format, solana-keygen). Never committed.
WALLET_KEYPAIR_PATH=./wallet.json

# Free World Cup tiers: 1 = 60s delay (devnet + mainnet), 12 = real-time (mainnet only)
TXLINE_SERVICE_LEVEL_ID=1
# Duration must be a multiple of 4 (on-chain program constraint)
TXLINE_DURATION_WEEKS=4

# Filled by the spike scripts as you go
TXLINE_JWT=
TXLINE_TX_SIG=
TXLINE_API_TOKEN=

# Supabase (Project Settings > API). The secret key is server-only: it
# bypasses row-level security, never ship it to a client bundle.
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=

# apps/web: worker API base. Empty = the deployed Railway worker.
# For local dev against a local worker: http://localhost:8787
NEXT_PUBLIC_WORKER_URL=

# Worker commitments: inline secret key (JSON array of 64 bytes) for hosts
# without a keypair file (Railway). Locally WALLET_KEYPAIR_PATH is enough.
# No wallet configured = commitments stay off (picks remain uncommitted).
WALLET_SECRET_KEY=
