# Network: devnet (safe first test, free SOL) or mainnet (Service Level 12 = real-time World Cup)
TXLINE_NETWORK=devnet

# Optional custom RPC. Empty = public RPC for the selected network.
SOLANA_RPC_URL=

# Path to the server wallet keypair (JSON array format, solana-keygen). Never committed.
WALLET_KEYPAIR_PATH=./wallet.json

# Free World Cup tiers: 1 = 60s delay (devnet + mainnet), 12 = real-time (mainnet only)
TXLINE_SERVICE_LEVEL_ID=1
# Duration must be a multiple of 4 (on-chain program constraint)
TXLINE_DURATION_WEEKS=4

# Filled by the spike scripts as you go
TXLINE_JWT=
TXLINE_TX_SIG=
TXLINE_API_TOKEN=
